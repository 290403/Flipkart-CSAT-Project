      "source": [
        "# Handling Outliers & Outlier treatments\n",
        "# Remove outliers in Item_price using IQR\n",
        "Q1 = df['Item_price'].quantile(0.25)\n",
        "Q3 = df['Item_price'].quantile(0.75)\n",
        "IQR = Q3 - Q1\n",
        "\n",
        "df = df[(df['Item_price'] >= Q1 - 1.5 * IQR) & (df['Item_price'] <= Q3 + 1.5 * IQR)]\n"
